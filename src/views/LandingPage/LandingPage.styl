:root {
    --ROCKETWIDTH: "min(20vw, 10rem)" % "";
    --ROCKETHEIGHT: calc(var(--ROCKETWIDTH) * 3);
}

#LandingPage {
    position: absolute;
    background-color: #001533;
    top: 0;
    right: 0;
    left: 0;
    bottom: 0;
    width: 100vw;
    height: 100vh;
    display: flex;
    align-content: center;
    justify-content: center;
    align-items: stretch;
    overflow: hidden;

    +portrait() {
        flex-direction: column;
    }

    .spacer {
        flex-grow: 0;
        flex-shrink: 1;
        +portrait() {
            height: "calc((100vh - 100vw) / 2)" % "";
        }
        +landscape() {
            width: "calc((100vw - 100vh) / 2)" % "";
        }
    }

    .mountain-background {
        flex-grow: 1;
        position: relative;
        text-align: center;
    }

    // Holds everything except the title animation so the whole scene can start
    // as a dark silhouette and gradually brighten while the title intro plays.
    .scene {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-image: url("/1.0/pages/home/background_no_planets_7_20_2026.svg");
        background-repeat: no-repeat;
    }

    .scene.intro-darkened {
        animation: intro-brighten 5s ease-out forwards;
    }

    .stars-animation {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: 2;
    }

    .raccoon-animation {
        position: absolute;
        bottom: 10%;
        left: 50%;
        transform: translateX(-49%);
        width: 32%;
        pointer-events: none;
        z-index: 3;
    }

    // Above the raccoon/stars but below the rockets, so a launching rocket
    // flies over the title/planets. During the intro the .scene filter makes
    // the scene a single layer, so the title still draws on top of it.
    .title-animation {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        pointer-events: none;
        z-index: z.rocket - 1;
    }

    .learn-to-play-rocket, .play-rocket {
        position: absolute;
        bottom: calc(var(--ROCKETHEIGHT) * 0.1 + 0.8rem);
        width: var(--ROCKETWIDTH);
        text-align: center;
        height: var(--ROCKETHEIGHT);
        z-index: z.rocket;
        cursor: pointer;

        .rocket-animation {
            position: absolute;
            top: 15%;
            left: 50%;
            width: 600%;
            height: 2500%;
            transform: translate(-50%, -50%);
            pointer-events: none;
        }

    }

    // Positioned relative to the square mountain-background so the popup lands
    // between the rocket and the raccoon regardless of viewport aspect ratio.
    // Proportions measured from the reference video.
    .rocket-popup {
        position: absolute;
        bottom: 28%;
        width: 39%;
        aspect-ratio: 1;
        pointer-events: none;
        z-index: z.rocket + 1;
    }

    .learn-popup {
        left: 17.5%;
    }

    .play-popup {
        right: 17.5%;
    }

    .learn-to-play-rocket {
        left: 5vw;
    }

    .play-rocket {
        right: 5vw;
    }
}

// Hold the scene as a dark silhouette while the title appears alone,
// then gradually brighten to full.
@keyframes intro-brighten {
    0% {
        filter: brightness(0.12);
    }
    45% {
        filter: brightness(0.12);
    }
    100% {
        filter: brightness(1);
    }
}
